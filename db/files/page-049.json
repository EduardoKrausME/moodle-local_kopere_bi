          "css": "",
          "html_before": "",
          "html_after": "",
          "commandsql": "SELECT kbi_ue.id,\n       kbi_c.fullname,\n       kbi_ue.timecreated,\n       kbi_u.firstname,\n       kbi_u.lastname,\n       kbi_u.email,\n       kbi_e.enrol,\n       kbi_e.cost,\n       kbi_e.currency\nFROM mdl_user_enrolments kbi_ue\n       JOIN mdl_enrol kbi_e ON kbi_e.id = kbi_ue.enrolid\n       JOIN mdl_user kbi_u ON kbi_u.id = kbi_ue.userid\n       JOIN mdl_course kbi_c ON kbi_c.id = kbi_e.courseid\nWHERE kbi_e.cost IS NOT NULL\n  AND kbi_c.id = :courseid\n  AND kbi_u.deleted = 0\n  AND kbi_u.suspended = 0\n  AND kbi_u.username != 'guest'\n  AND kbi_c.visible = 1\n  AND kbi_ue.status = 0\n  AND kbi_e.status = 0\nORDER BY kbi_ue.timecreated DESC, kbi_c.fullname, kbi_u.lastname, kbi_u.firstname",
          "cache": "1h",
          "reload": "none",
