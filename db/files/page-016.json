                    "title": "lang::report_page_016_title::local_kopere_bi",
                    "refkey": "el_report111_os_and_browser_stats_by_user",
                    "block_num": 1,
                    "type": "table",
                    "theme": "light",
                    "css": "",
                    "html_before": "",
                    "html_after": "",
                    "commandsql": "SELECT MAX(lit.id) AS id,\n       u.id        AS userid,\n       u.firstname,\n       u.lastname,\n       u.email,\n       u.idnumber,\n       c.id        AS courseid,\n       c.fullname  AS course,\n       cc.name     AS category_name,\n       ROUND((SUM(CASE WHEN lit.useragent = 'Firefox' THEN lit.timespend ELSE 0 END) * 100) / SUM(lit.timespend),\n             2)    AS firefox,\n       ROUND((SUM(CASE WHEN lit.useragent = 'Chrome' THEN lit.timespend ELSE 0 END) * 100) / SUM(lit.timespend),\n             2)    AS chrome,\n       ROUND((SUM(CASE WHEN lit.useragent = 'Safari' THEN lit.timespend ELSE 0 END) * 100) / SUM(lit.timespend),\n             2)    AS safari,\n       ROUND((SUM(CASE\n                    WHEN lit.useragent = 'Microsoft Edge' OR lit.useragent = 'Edge' THEN lit.timespend\n                    ELSE 0 END) * 100) / SUM(lit.timespend),\n             2)    AS microsoft_edge,\n       ROUND((SUM(CASE WHEN lit.useragent = 'Opera' THEN lit.timespend ELSE 0 END) * 100) / SUM(lit.timespend),\n             2)    AS opera,\n       ROUND((SUM(CASE WHEN lit.useragent = 'Mobile browser' THEN lit.timespend ELSE 0 END) * 100) / SUM(lit.timespend),\n             2)    AS mobile_browser,\n       ROUND((SUM(CASE\n                    WHEN lit.useragent = 'Unknown Browser' OR lit.useragent IS NULL THEN lit.timespend\n                    ELSE 0 END) * 100) / SUM(lit.timespend),\n             2)    AS other_browser,\n       ROUND((SUM(CASE WHEN lit.useros LIKE 'Windows%' THEN lit.timespend ELSE 0 END) * 100) / SUM(lit.timespend),\n             2)    AS windows,\n       ROUND((SUM(CASE WHEN lit.useros LIKE 'Mac OS%' THEN lit.timespend ELSE 0 END) * 100) / SUM(lit.timespend),\n             2)    AS mac_os,\n       ROUND((SUM(CASE WHEN lit.useros = 'Linux' OR lit.useros = 'Ubuntu' THEN lit.timespend ELSE 0 END) * 100) / SUM(lit.timespend),\n             2)    AS linux,\n       ROUND((SUM(CASE\n                    WHEN lit.useros = 'iPhone' OR lit.useros = 'iPod' OR lit.useros = 'iPad' THEN lit.timespend\n                    ELSE 0 END) * 100) / SUM(lit.timespend),\n             2)    AS ios,\n       ROUND((SUM(CASE WHEN lit.useros = 'Android' THEN lit.timespend ELSE 0 END) * 100) / SUM(lit.timespend),\n             2)    AS android,\n       ROUND((SUM(CASE WHEN lit.useros = 'Mobile' THEN lit.timespend ELSE 0 END) * 100) / SUM(lit.timespend),\n             2)    AS mobile,\n       ROUND((SUM(CASE\n                    WHEN lit.useros = 'Unknown OS Platform' OR lit.useros IS NULL THEN lit.timespend\n                    ELSE 0 END) * 100) / SUM(lit.timespend),\n             2)    AS other_platform\nFROM mdl_local_kopere_bi_tracking lit\n       LEFT JOIN mdl_course c ON c.id = lit.courseid\n       LEFT JOIN mdl_course_categories cc ON cc.id = c.category\n       LEFT JOIN mdl_user u ON u.id = lit.userid\nWHERE lit.page = 'course'\n  AND lit.courseid > 1\n  AND c.id IS NOT NULL\n  AND u.deleted = 0\n  AND u.suspended = 0\n  AND u.username != 'guest'\n  AND c.visible = 1\nGROUP BY lit.courseid, lit.userid, u.id, c.id, cc.id",
                    "cache": "1h",
                    "reload": "none",
