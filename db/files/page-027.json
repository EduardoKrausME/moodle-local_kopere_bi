          "html_before": "",
          "html_after": "",
          "commandsql": "SELECT kbi_lit.id                                                        AS lid,\n       kbi_u.firstname,\n       kbi_u.lastname,\n       kbi_u.email,\n       kbi_c.fullname,\n       kbi_c.shortname,\n       CASE WHEN kbi_lit.visits IS NULL THEN 0 ELSE kbi_lit.visits END       AS visits,\n       CASE WHEN kbi_lit.timespend IS NULL THEN 0 ELSE kbi_lit.timespend END AS timespend,\n       kbi_lit.firstaccess,\n       kbi_lit.lastaccess,\n       kbi_cm.instance,\n       kbi_m.name                                                        AS module\nFROM mdl_role_assignments kbi_ra\n       JOIN mdl_user kbi_u ON kbi_ra.userid = kbi_u.id\n       JOIN mdl_context kbi_ctx ON kbi_ctx.id = kbi_ra.contextid\n       JOIN mdl_course kbi_c ON kbi_c.id = kbi_ctx.instanceid\n       LEFT JOIN mdl_course_modules kbi_cm ON kbi_cm.course = kbi_c.id\n       LEFT JOIN mdl_modules kbi_m ON kbi_m.id = kbi_cm.module\n       LEFT JOIN mdl_local_kopere_bi_tracking kbi_lit ON kbi_lit.userid = kbi_u.id AND kbi_lit.param = kbi_cm.id AND kbi_lit.page = 'module'\nWHERE kbi_ctx.contextlevel = 50\n  AND kbi_c.id = :courseid\n  AND kbi_ra.roleid = 3\n  AND kbi_u.deleted = 0\n  AND kbi_u.suspended = 0\n  AND kbi_u.username != 'guest'\n  AND kbi_c.visible = 1\n  AND kbi_cm.visible = 1",
          "cache": "1h",
