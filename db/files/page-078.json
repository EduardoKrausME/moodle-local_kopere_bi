          "commandsql": "SELECT kbi_s.id,\n       kbi_c.fullname,\n       kbi_s.name,\n       kbi_s.timemodified,\n       SUM(CASE WHEN element = 'x.start.time' THEN 1 ELSE 0 END) AS attempts,\n       MAX(sl.visits)                                            AS visits,\n       SUM(CASE\n             WHEN element = 'cmi.core.total_time' THEN TIME_TO_SEC(value)\n             ELSE 0 END)                                         AS duration\nFROM mdl_scorm kbi_s\n       JOIN mdl_course kbi_c ON kbi_c.id = kbi_s.course\n       LEFT JOIN mdl_scorm_scoes_track kbi_sst\n         ON kbi_sst.scormid = kbi_s.id AND (element = 'cmi.core.total_time' OR element = 'x.start.time')\nWHERE kbi_s.id > 0\n  AND kbi_c.id = :courseid\n  AND kbi_c.visible = 1\nGROUP BY kbi_s.id, kbi_c.id\nORDER BY kbi_c.fullname, kbi_s.name",
