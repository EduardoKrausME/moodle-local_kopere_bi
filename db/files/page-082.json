          "block_num": 1,
          "type": "table",
          "theme": "light",
          "css": "",
          "html_before": "",
          "html_after": "",
          "commandsql": "SELECT kbi_u.firstname,\n       kbi_u.lastname,\n       kbi_u.email,\n       kbi_mfc.timemodified                    as feedback_time,\n       kbi_cc.timecompleted,\n       kbi_mfi.presentation,\n       kbi_mfi.typ,\n       kbi_mfi.id                              AS q_id,\n       kbi_mfi.label                           AS question_number,\n       kbi_mfi.name                            as question,\n       kbi_mfv.value                           as answer,\n       kbi_mf.name                             as feedback,\n       kbi_mf.id                               as feedback_id,\n       kbi_c.id                                as course_id,\n       kbi_c.idnumber                          as course_idnumber,\n       kbi_c.fullname                          as course_name,\n       kbi_c.shortname                         as course_shortname,\n       ROUND((CASE\n                WHEN kbi_g.rawgrademax > 0 THEN (kbi_g.finalgrade / kbi_g.rawgrademax) * 100\n                ELSE kbi_g.finalgrade END), 0) AS grade\nFROM mdl_feedback kbi_mf\n       JOIN mdl_course kbi_c ON kbi_c.id = kbi_mf.course\n       JOIN mdl_feedback_item kbi_mfi ON kbi_mfi.feedback = kbi_mf.id\n       LEFT JOIN mdl_feedback_value kbi_mfv ON kbi_mfv.item = kbi_mfi.id\n       LEFT JOIN mdl_feedback_completed kbi_mfc ON kbi_mfc.id = kbi_mfv.completed\n       LEFT JOIN mdl_user kbi_u ON kbi_mfc.userid = kbi_u.id\n       LEFT JOIN mdl_grade_items kbi_gi ON kbi_gi.itemtype = 'course' AND kbi_gi.courseid = kbi_c.id\n       LEFT JOIN mdl_grade_grades kbi_g ON kbi_g.userid = kbi_u.id AND kbi_g.itemid = kbi_gi.id AND kbi_g.finalgrade IS NOT NULL\n       LEFT JOIN mdl_course_completions kbi_cc ON kbi_cc.userid = kbi_u.id AND kbi_cc.course = kbi_c.id\nWHERE kbi_mf.id > 0\n  AND kbi_mf.course = :courseid\n  AND kbi_u.deleted = 0\n  AND kbi_u.suspended = 0\n  AND kbi_u.username != 'guest'\n  AND kbi_c.visible = 1",
          "cache": "1h",
          "reload": "none",
