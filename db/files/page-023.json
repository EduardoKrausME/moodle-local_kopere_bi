          "html_before": "",
          "html_after": "",
          "commandsql": "SELECT kbi_ue.id,\n       kbi_ue.timecreated                      AS enrolled,\n       kbi_ue.timeend,\n       kbi_ue.status                           AS enroll_status,\n       kbi_ul.timeaccess,\n       ROUND((CASE\n                WHEN kbi_g.rawgrademax > 0 THEN (kbi_g.finalgrade / kbi_g.rawgrademax) * 100\n                ELSE kbi_g.finalgrade END), 0) AS grade,\n       kbi_c.enablecompletion,\n       kbi_cc.timecompleted                    AS complete,\n       kbi_u.id                                AS uid,\n       kbi_u.email,\n       kbi_u.idnumber,\n       kbi_u.phone1,\n       kbi_u.phone2,\n       kbi_u.institution,\n       kbi_u.department,\n       kbi_u.address,\n       kbi_u.city,\n       kbi_u.country,\n       kbi_u.firstname,\n       kbi_u.lastname,\n       kbi_u.username,\n       kbi_e.enrol                             AS enrols,\n       kbi_c.id                                AS cid,\n       kbi_c.fullname                          AS course,\n       kbi_c.shortname,\n       kbi_c.timemodified                      AS start_date,\n       ''                                  as cohortname,\n       l.timespend,\n       l.visits\nFROM mdl_user_enrolments kbi_ue\n       JOIN mdl_enrol kbi_e ON kbi_e.id = kbi_ue.enrolid\n       JOIN mdl_user kbi_u ON kbi_u.id = kbi_ue.userid\n       JOIN mdl_course kbi_c ON kbi_c.id = kbi_e.courseid\n       LEFT JOIN mdl_user_lastaccess kbi_ul ON kbi_ul.courseid = kbi_c.id AND kbi_ul.userid = kbi_u.id\n       LEFT JOIN mdl_course_completions kbi_cc ON kbi_cc.course = kbi_e.courseid AND kbi_cc.userid = kbi_ue.userid\n       LEFT JOIN mdl_grade_items kbi_gi ON kbi_gi.itemtype = 'course' AND kbi_gi.courseid = kbi_e.courseid\n       LEFT JOIN mdl_grade_grades kbi_g ON kbi_g.userid = kbi_u.id AND kbi_g.itemid = kbi_gi.id AND kbi_g.finalgrade IS NOT NULL\n       LEFT JOIN (SELECT courseid,\n                         userid,\n                         SUM(timespend) AS timespend,\n                         SUM(visits)    AS visits\n                  FROM mdl_local_kopere_bi_tracking\n                  GROUP BY courseid, userid) l ON l.courseid = kbi_c.id AND l.userid = kbi_u.id\nWHERE kbi_ue.id > 0\n  AND kbi_c.id = :courseid\n  AND kbi_u.deleted = 0\n  AND kbi_u.suspended = 0\n  AND kbi_u.username != 'guest'\n  AND kbi_c.visible = 1\n  AND kbi_ue.status = 0\n  AND kbi_e.status = 0\nORDER BY kbi_c.fullname, kbi_u.lastname, kbi_u.firstname",
