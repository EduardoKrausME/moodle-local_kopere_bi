          "block_num": 1,
          "type": "table",
          "theme": "light",
          "css": "",
          "html_before": "",
          "html_after": "",
          "commandsql": "SELECT kbi_u.id,\n       kbi_u.firstname,\n       kbi_u.lastname,\n       kbi_u.email,\n       kbi_u.phone1,\n       kbi_u.phone2,\n       kbi_u.institution,\n       kbi_u.department,\n       kbi_u.address,\n       kbi_u.city,\n       kbi_u.country,\n       COUNT(DISTINCT kbi_qa.quiz) AS submitted,\n       COUNT(DISTINCT kbi_qa.id)   AS attempted\nFROM mdl_quiz_attempts kbi_qa\n       JOIN mdl_quiz kbi_q ON kbi_q.id = kbi_qa.quiz\n       JOIN mdl_course kbi_c ON kbi_c.id = kbi_q.course\n       JOIN mdl_user kbi_u ON kbi_u.id = kbi_qa.userid\nWHERE kbi_c.id = :courseid\n  AND kbi_u.deleted = 0\n  AND kbi_u.suspended = 0\n  AND kbi_u.username != 'guest'\n  AND kbi_c.visible = 1\nGROUP BY kbi_u.id,\n         kbi_u.firstname,\n         kbi_u.lastname,\n         kbi_u.email,\n         kbi_u.phone1,\n         kbi_u.phone2,\n         kbi_u.institution,\n         kbi_u.department,\n         kbi_u.address,\n         kbi_u.city,\n         kbi_u.country\nORDER BY kbi_u.lastname, kbi_u.firstname",
          "cache": "1h",
          "reload": "none",
