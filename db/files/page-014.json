          "theme": "light",
          "css": "",
          "html_before": "",
          "html_after": "",
          "commandsql": "SELECT kbi_u.id,\n       kbi_u.firstname,\n       kbi_u.lastname,\n       kbi_u.email,\n       kbi_u.phone1,\n       kbi_u.phone2,\n       kbi_u.institution,\n       kbi_u.department,\n       kbi_u.address,\n       kbi_u.city,\n       kbi_u.country,\n       kbi_u.timecreated,\n       kbi_u.firstaccess,\n       kbi_u.lastaccess,\n       lit1.timespend_site,\n       lit2.timespend_courses,\n       lit3.timespend_activities\nFROM mdl_user kbi_u\n       LEFT JOIN (SELECT kbi_t.userid, SUM(timespend) AS timespend_site\n                  FROM mdl_local_kopere_bi_tracking kbi_t\n                  WHERE kbi_t.id > 0\n                  GROUP BY kbi_t.userid) lit1 ON lit1.userid = kbi_u.id\n       LEFT JOIN (SELECT kbi_t.userid, SUM(timespend) AS timespend_courses\n                  FROM mdl_local_kopere_bi_tracking kbi_t\n                  WHERE kbi_t.courseid > 0\n                  GROUP BY kbi_t.userid) lit2 ON lit2.userid = kbi_u.id\n       LEFT JOIN (SELECT kbi_t.userid, SUM(timespend) AS timespend_activities\n                  FROM mdl_local_kopere_bi_tracking kbi_t\n                  WHERE kbi_t.page = 'module'\n                  GROUP BY kbi_t.userid) lit3 ON lit3.userid = kbi_u.id\nWHERE kbi_u.id > 0\n  AND kbi_u.deleted = 0\n  AND kbi_u.suspended = 0\n  AND kbi_u.username != 'guest'",
          "cache": "1h",
          "reload": "none",
