          "title": "lang::report_page_018_title::local_kopere_bi",
          "refkey": "kbi_el_user_engagement",
          "block_num": 1,
          "type": "table",
          "theme": "light",
          "css": "",
          "html_before": "",
          "html_after": "",
          "commandsql": "SELECT kbi_u.id,\n       kbi_u.firstname,\n       kbi_u.lastname,\n       kbi_u.email,\n       kbi_u.timecreated,\n       COUNT(DISTINCT kbi_ctx.instanceid) as courses,\n       MAX(lit.timesite)              AS timesite,\n       MAX(lit.timecourses)           AS timecourses,\n       MAX(lit.timeactivities)        AS timeactivities\nFROM mdl_role_assignments kbi_ra\n       JOIN mdl_user kbi_u ON kbi_u.id = kbi_ra.userid\n       JOIN mdl_context kbi_ctx ON kbi_ctx.id = kbi_ra.contextid AND kbi_ctx.contextlevel = 50\n       LEFT JOIN (SELECT userid,\n                         SUM(timespend)                                              as timesite,\n                         SUM(CASE WHEN courseid > 0 THEN timespend ELSE null END)    as timecourses,\n                         SUM(CASE WHEN page = 'module' THEN timespend ELSE null END) as timeactivities\n                  FROM mdl_local_kopere_bi_tracking\n                  GROUP BY userid) as lit ON lit.userid = kbi_u.id\nWHERE kbi_u.id > 0\n  AND kbi_u.deleted = 0\n  AND kbi_u.suspended = 0\n  AND kbi_u.username != 'guest'\n  AND kbi_ra.roleid = 5\nGROUP BY kbi_u.id",
          "cache": "1h",
          "reload": "none",
