          "css": "",
          "html_before": "",
          "html_after": "",
          "commandsql": "SELECT kbi_f.id,\n       kbi_c.id                                                                              AS courseid,\n       kbi_c.fullname,\n       kbi_u.id                                                                              AS userid,\n       kbi_u.firstname,\n       kbi_u.lastname,\n       kbi_u.username,\n       CONCAT('/', kbi_ctx.id, '/mod_resource/content/', kbi_r.revision, kbi_f.filepath, kbi_f.filename) AS file_path,\n       kbi_f.filename,\n       kbi_f.timecreated\nFROM mdl_course kbi_c\n       JOIN mdl_resource kbi_r ON kbi_r.course = kbi_c.id\n       JOIN mdl_modules kbi_m ON kbi_m.name = 'resource'\n       JOIN mdl_course_modules kbi_cm ON kbi_cm.module = kbi_m.id AND kbi_cm.instance = kbi_r.id\n       JOIN mdl_context kbi_ctx ON kbi_ctx.contextlevel = 70 AND kbi_ctx.instanceid = kbi_cm.id\n       JOIN mdl_files kbi_f\n         ON kbi_f.component = 'mod_resource' AND kbi_f.filearea = 'content' AND kbi_f.itemid = 0 AND kbi_f.filesize > 0 AND\n            kbi_ctx.id = kbi_f.contextid\n       JOIN mdl_user kbi_u ON kbi_u.id = kbi_f.userid\nWHERE kbi_c.id > 0\n  AND kbi_c.id = :courseid\n  AND kbi_c.visible = 1\n  AND kbi_u.deleted = 0\n  AND kbi_u.suspended = 0\n  AND kbi_u.username != 'guest'\nORDER BY kbi_c.fullname, kbi_f.filename",
          "cache": "1h",
          "reload": "none",
