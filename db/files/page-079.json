          "css": "",
          "html_before": "",
          "html_after": "",
          "commandsql": "SELECT kbi_c.id,\n       kbi_c.fullname,\n       count(kbi_s.id) as scorms,\n       (SELECT DISTINCT CONCAT(kbi_u.firstname, ' ', kbi_u.lastname)\n        FROM mdl_role_assignments kbi_ra\n               JOIN mdl_user kbi_u ON kbi_ra.userid = kbi_u.id\n               JOIN mdl_context kbi_ctx ON kbi_ctx.id = kbi_ra.contextid\n        WHERE kbi_ctx.instanceid = kbi_c.id\n          AND kbi_ctx.contextlevel = 50\n          AND kbi_ra.roleid = 3\n        LIMIT 1)   AS teacher\nFROM mdl_course kbi_c\n       LEFT JOIN mdl_scorm kbi_s ON kbi_s.course = kbi_c.id\nWHERE kbi_c.category > 0\n  AND kbi_c.id = :courseid\n  AND kbi_c.visible = 1\nGROUP BY kbi_c.id",
