          "css": "",
          "html_before": "",
          "html_after": "",
          "commandsql": "SELECT kbi_co.id,\n       kbi_co.name,\n       COUNT(DISTINCT kbi_qa.quiz) AS submitted,\n       COUNT(DISTINCT kbi_qa.id)   AS attempted\nFROM mdl_quiz_attempts kbi_qa\n       JOIN mdl_quiz kbi_q ON kbi_q.id = kbi_qa.quiz\n       JOIN mdl_course kbi_c ON kbi_c.id = kbi_q.course\n       JOIN mdl_cohort_members kbi_cm ON kbi_cm.userid = kbi_qa.userid\n       JOIN mdl_cohort kbi_co ON kbi_co.id = kbi_cm.cohortid\nWHERE kbi_c.id = :courseid\n  AND kbi_c.visible = 1\nGROUP BY kbi_co.id, kbi_co.name\nORDER BY kbi_co.name",
          "cache": "1h",
          "reload": "none",
