          "block_num": 1,
          "type": "table",
          "theme": "light",
          "css": "",
          "html_before": "",
          "html_after": "",
          "commandsql": "SELECT kbi_q.id,\n       kbi_q.name,\n       kbi_q.course,\n       kbi_c.fullname,\n       MAX(ql.questions)                       AS questions,\n       kbi_q.timemodified,\n       kbi_q.timeopen,\n       kbi_q.timeclose,\n       avg((kbi_qa.sumgrades / kbi_q.sumgrades) * 100) AS grade,\n       count(distinct(kbi_qa.id))                  AS attempts,\n       sum(kbi_qa.timefinish - kbi_qa.timestart)       AS duration\nFROM mdl_quiz kbi_q\n       JOIN mdl_course kbi_c ON kbi_c.id = kbi_q.course\n       LEFT JOIN mdl_quiz_attempts kbi_qa ON kbi_qa.quiz = kbi_q.id\n       LEFT JOIN (SELECT quizid, count(*) questions FROM mdl_quiz_slots GROUP BY quizid) ql ON ql.quizid = kbi_q.id\n       LEFT JOIN mdl_modules kbi_m ON kbi_m.name = 'quiz'\n       LEFT JOIN mdl_course_modules kbi_cm ON kbi_cm.module = kbi_m.id AND kbi_cm.course = kbi_c.id AND kbi_cm.instance = kbi_q.id\nWHERE kbi_q.id > 0\n  AND kbi_q.course = :courseid\n  AND kbi_c.visible = 1\nGROUP BY kbi_q.id, kbi_c.id\nORDER BY kbi_q.name",
          "cache": "1h",
          "reload": "none",
