          "html_before": "",
          "html_after": "",
          "commandsql": "SELECT kbi_a.name                               as assignment,\n       kbi_a.duedate,\n       kbi_c.fullname                           as course,\n       kbi_s.status,\n       kbi_s.timemodified                       AS submitted,\n       kbi_u.email,\n       kbi_u.idnumber,\n       kbi_u.phone1,\n       kbi_u.phone2,\n       kbi_u.institution,\n       kbi_u.department,\n       kbi_u.address,\n       kbi_u.city,\n       kbi_u.country,\n       kbi_u.firstname,\n       kbi_u.lastname,\n       ROUND((CASE\n                WHEN kbi_gg.rawgrademax > 0 THEN (kbi_gg.finalgrade / kbi_gg.rawgrademax) * 100\n                ELSE kbi_gg.finalgrade END), 0) AS grade\nFROM mdl_assign kbi_a\n       LEFT JOIN (SELECT kbi_e.courseid, kbi_ue.userid\n                  FROM mdl_user_enrolments kbi_ue, mdl_enrol kbi_e\n                  WHERE kbi_e.id = kbi_ue.enrolid\n                  GROUP BY kbi_e.courseid, kbi_ue.userid) ue ON kbi_ue.courseid = kbi_a.course\n       LEFT JOIN mdl_user kbi_u ON kbi_u.id = kbi_ue.userid\n       LEFT JOIN mdl_assign_submission kbi_s ON kbi_s.assignment = kbi_a.id AND kbi_s.userid = kbi_u.id\n       LEFT JOIN mdl_course kbi_c ON kbi_c.id = kbi_a.course\n       LEFT JOIN mdl_modules kbi_m ON kbi_m.name = 'assign'\n       LEFT JOIN mdl_course_modules kbi_cm ON kbi_cm.instance = kbi_a.id AND kbi_cm.module = kbi_m.id\n       LEFT JOIN mdl_grade_items kbi_gi\n         ON kbi_gi.courseid = kbi_c.id AND kbi_gi.itemtype = 'mod' AND kbi_gi.itemmodule = kbi_m.name AND kbi_gi.iteminstance = kbi_cm.instance\n       LEFT JOIN mdl_grade_grades kbi_gg ON kbi_gg.itemid = kbi_gi.id AND kbi_gg.userid = kbi_u.id\nWHERE kbi_a.id > 0\n  AND kbi_c.id = :courseid\n  AND kbi_u.deleted = 0\n  AND kbi_u.suspended = 0\n  AND kbi_u.username != 'guest'\n  AND kbi_c.visible = 1\n  AND kbi_cm.visible = 1\n  AND (kbi_s.timemodified > kbi_a.duedate or kbi_s.timemodified IS NULL)\nORDER BY kbi_c.fullname, kbi_a.name, kbi_u.lastname, kbi_u.firstname",
