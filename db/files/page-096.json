          "html_before": "",
          "html_after": "",
          "commandsql": "SELECT kbi_la.id       AS id,\n       kbi_la.timeseen,\n       kbi_c.id        AS courseid,\n       kbi_c.fullname,\n       kbi_c.shortname,\n       kbi_u.id        AS userid,\n       kbi_u.firstname,\n       kbi_u.lastname,\n       kbi_u.email,\n       kbi_u.username,\n       t.id        AS teacher_userid,\n       t.firstname AS teacher_firstname,\n       t.lastname  As teacher_lastname,\n       t.email     AS teacher_email,\n       t.username  AS teacher_username,\n       kbi_l.name      AS lesson_name,\n       kbi_lp.contents AS question_name,\n       kbi_lp.qtype,\n       kbi_la.useranswer\nFROM mdl_lesson kbi_l\n       JOIN mdl_lesson_attempts kbi_la ON kbi_la.lessonid = kbi_l.id\n       JOIN mdl_course kbi_c ON kbi_c.id = kbi_l.course\n       JOIN mdl_user kbi_u ON kbi_u.id = kbi_la.userid\n       JOIN mdl_lesson_pages kbi_lp ON kbi_lp.id = kbi_la.pageid\n       LEFT JOIN (SELECT a.courseid, kbi_u.firstname, kbi_u.lastname, kbi_u.email, kbi_u.username, kbi_u.id\n                  FROM (SELECT kbi_ctx.instanceid AS courseid, MIN(kbi_ra.userid) AS userid\n                        FROM mdl_role_assignments kbi_ra\n                               JOIN mdl_context kbi_ctx ON kbi_ctx.id = kbi_ra.contextid\n                        WHERE kbi_ctx.contextlevel = 50\n                          AND kbi_ra.roleid = 3\n                        GROUP BY kbi_ctx.instanceid) a\n                         JOIN mdl_user kbi_u ON kbi_u.id = a.userid) t ON t.courseid = kbi_c.id\nWHERE kbi_l.id > 0\n  AND kbi_u.deleted = 0\n  AND kbi_u.suspended = 0\n  AND kbi_u.username != 'guest'\n  AND kbi_c.visible = 1",
          "cache": "1h",
          "reload": "none",
