          "html_before": "",
          "html_after": "",
          "commandsql": "SELECT kbi_ue.id,\n       kbi_ue.timecreated                      as enrolled,\n       kbi_cc.timecompleted                    as complete,\n       ROUND((CASE\n                WHEN kbi_g.rawgrademax > 0 THEN (kbi_g.finalgrade / kbi_g.rawgrademax) * 100\n                ELSE kbi_g.finalgrade END), 0) AS grade,\n       kbi_u.id                                as uid,\n       kbi_u.email,\n       kbi_u.firstname,\n       kbi_u.lastname,\n       kbi_c.id                                as cid,\n       kbi_c.enablecompletion,\n       kbi_c.fullname                          as course,\n       ''                                  as cohortname\nFROM mdl_user_enrolments kbi_ue\n       JOIN mdl_enrol kbi_e ON kbi_e.id = kbi_ue.enrolid\n       JOIN mdl_user kbi_u ON kbi_u.id = kbi_ue.userid\n       JOIN mdl_course kbi_c ON kbi_c.id = kbi_e.courseid\n       LEFT JOIN mdl_course_completions kbi_cc ON kbi_cc.course = kbi_e.courseid AND kbi_cc.userid = kbi_u.id\n       LEFT JOIN mdl_grade_items kbi_gi ON kbi_gi.courseid = kbi_e.courseid AND kbi_gi.itemtype = 'course'\n       LEFT JOIN mdl_grade_grades kbi_g ON kbi_g.itemid = kbi_gi.id AND kbi_g.userid = kbi_u.id\nWHERE kbi_ue.id > 0\n  AND kbi_c.id = :courseid\n  AND kbi_u.deleted = 0\n  AND kbi_u.suspended = 0\n  AND kbi_u.username != 'guest'\n  AND kbi_c.visible = 1\n  AND kbi_ue.status = 0\n  AND kbi_e.status = 0\nORDER BY kbi_c.fullname, kbi_u.lastname, kbi_u.firstname",
          "cache": "1h",
          "reload": "none",
