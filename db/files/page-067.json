          "html_before": "",
          "html_after": "",
          "commandsql": "SELECT kbi_qa.id,\n       kbi_q.name,\n       kbi_u.email,\n       kbi_q.course,\n       kbi_q.timeclose,\n       kbi_c.fullname,\n       kbi_qa.timestart,\n       kbi_qa.timefinish,\n       kbi_qa.state,\n       (kbi_qa.timefinish - kbi_qa.timestart)                  as duration,\n       (kbi_qa.sumgrades / MAX(kbi_q.sumgrades) * 100)         as grade,\n       kbi_u.firstname,\n       kbi_u.lastname,\n       GROUP_CONCAT(DISTINCT kbi_t.rawname SEPARATOR ', ') as tags,\n       ''                                              AS cohortname\nFROM (SELECT kbi_ctx.instanceid, kbi_ra1.userid\n      FROM mdl_context kbi_ctx\n             JOIN mdl_role_assignments kbi_ra1 ON kbi_ra1.contextid = kbi_ctx.id AND kbi_ra1.roleid = 5\n      WHERE kbi_ctx.contextlevel = 50\n      GROUP BY kbi_ctx.instanceid, kbi_ra1.userid) ra\n       JOIN mdl_modules kbi_m ON kbi_m.name = 'quiz'\n       JOIN mdl_course_modules kbi_cm ON kbi_cm.course = ra.instanceid AND kbi_cm.module = kbi_m.id\n       JOIN mdl_quiz kbi_q ON kbi_q.id = kbi_cm.instance\n       JOIN mdl_user kbi_u ON kbi_u.id = ra.userid\n       JOIN mdl_course kbi_c ON kbi_c.id = ra.instanceid\n       LEFT JOIN mdl_quiz_attempts kbi_qa ON kbi_qa.quiz = kbi_q.id AND kbi_qa.userid = ra.userid\n       LEFT JOIN mdl_tag_instance kbi_ti ON kbi_ti.itemtype = 'course_modules' AND kbi_ti.itemid = kbi_cm.id\n       LEFT JOIN mdl_tag kbi_t ON kbi_t.id = kbi_ti.tagid\nWHERE ra.instanceid > 0\n  AND ra.instanceid = :courseid\n  AND kbi_u.deleted = 0\n  AND kbi_u.suspended = 0\n  AND kbi_u.username != 'guest'\n  AND kbi_c.visible = 1\nGROUP BY kbi_u.id, kbi_q.id, kbi_c.id, kbi_qa.id",
          "cache": "1h",
