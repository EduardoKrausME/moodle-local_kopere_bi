          "css": "",
          "html_before": "",
          "html_after": "",
          "commandsql": "SELECT CONCAT(kbi_qa.id, '-', kbi_qatt.slot) AS id,\n       kbi_c.id                              AS courseid,\n       kbi_c.fullname                        AS course,\n       kbi_cm.id                             AS cmid,\n       kbi_qz.id                             AS quizid,\n       kbi_qz.name                           AS quiz_name,\n       kbi_u.id                              AS userid,\n       kbi_u.firstname,\n       kbi_u.lastname,\n       kbi_u.email,\n       kbi_qa.id                             AS quiz_attempt_id,\n       kbi_qa.attempt,\n       kbi_qa.timestart,\n       kbi_qa.timefinish,\n       kbi_qa.state                          AS attempt_state,\n       kbi_qatt.slot,\n       kbi_q.id                              AS questionid,\n       kbi_q.name                            AS question_name,\n       kbi_q.qtype,\n       kbi_qatt.questionsummary,\n       kbi_qatt.responsesummary,\n       kbi_qatt.rightanswer,\n       kbi_qas.state                         AS question_state,\n       kbi_qas.fraction,\n       ROUND(kbi_qatt.maxmark * COALESCE(kbi_qas.fraction, 0), 2) AS question_grade,\n       kbi_qatt.maxmark,\n       CASE\n         WHEN kbi_qas.state = 'gradedright' THEN 1\n         ELSE 0\n       END AS is_correct\nFROM mdl_quiz_attempts kbi_qa\n       JOIN mdl_quiz kbi_qz ON kbi_qz.id = kbi_qa.quiz\n       JOIN mdl_course kbi_c ON kbi_c.id = kbi_qz.course\n       JOIN mdl_user kbi_u ON kbi_u.id = kbi_qa.userid\n       JOIN mdl_question_attempts kbi_qatt ON kbi_qatt.questionusageid = kbi_qa.uniqueid\n       JOIN mdl_question kbi_q ON kbi_q.id = kbi_qatt.questionid\n       LEFT JOIN mdl_question_attempt_steps kbi_qas ON kbi_qas.questionattemptid = kbi_qatt.id\n             AND kbi_qas.sequencenumber = (\n                 SELECT MAX(kbi_qas2.sequencenumber)\n                 FROM mdl_question_attempt_steps kbi_qas2\n                 WHERE kbi_qas2.questionattemptid = kbi_qatt.id\n             )\n       JOIN mdl_modules kbi_m ON kbi_m.name = 'quiz'\n       JOIN mdl_course_modules kbi_cm ON kbi_cm.course = kbi_c.id AND kbi_cm.module = kbi_m.id AND kbi_cm.instance = kbi_qz.id\nWHERE kbi_qa.preview = 0\n  AND kbi_c.visible = 1\n  AND kbi_cm.visible = 1\n  AND kbi_u.deleted = 0\n  AND kbi_u.suspended = 0\n  AND kbi_u.username <> 'guest'\nORDER BY kbi_c.fullname, kbi_qz.name, kbi_u.lastname, kbi_u.firstname, kbi_qa.attempt, kbi_qatt.slot",
          "cache": "1h",
          "reload": "none",
