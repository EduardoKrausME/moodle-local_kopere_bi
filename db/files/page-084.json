          "commandsql": "SELECT kbi_ce.id,\n       kbi_u.id AS userid,\n       kbi_u.firstname,\n       kbi_u.lastname,\n       kbi_c.shortname,\n       kbi_ce.url,\n       kbi_ce.descidentifier,\n       kbi_ce.desccomponent,\n       kbi_ce.desca,\n       kbi_ce.timecreated\nFROM mdl_competency_evidence kbi_ce\n       LEFT JOIN mdl_competency_usercomp kbi_cu ON kbi_ce.usercompetencyid = kbi_cu.id\n       LEFT JOIN mdl_competency kbi_c ON kbi_c.id = kbi_cu.competencyid\n       LEFT JOIN mdl_user kbi_u ON kbi_u.id = kbi_cu.userid\nWHERE kbi_u.id IS NOT NULL\nORDER BY kbi_u.lastname, kbi_u.firstname, kbi_ce.timecreated DESC",
