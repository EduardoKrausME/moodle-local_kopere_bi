          "commandsql": "SELECT kbi_bi.id,\n       kbi_u.id       AS userid,\n       kbi_u.firstname,\n       kbi_u.lastname,\n       kbi_u.email,\n       kbi_c.fullname as course,\n       kbi_c.id       AS cid,\n       kbi_b.name,\n       kbi_bi.dateissued,\n       kbi_bi.dateexpire\nFROM mdl_badge kbi_b\n       LEFT JOIN mdl_badge_issued kbi_bi ON kbi_bi.badgeid = kbi_b.id\n       LEFT JOIN mdl_user kbi_u ON kbi_u.id = kbi_bi.userid\n       LEFT JOIN mdl_course kbi_c ON kbi_c.id = kbi_b.courseid\nWHERE kbi_bi.id IS NOT NULL\n  AND kbi_bi.visible = 1\n  AND (kbi_b.courseid IS NOT NULL)\nORDER BY kbi_bi.dateissued DESC, kbi_u.lastname, kbi_u.firstname",
