          "css": "",
          "html_before": "",
          "html_after": "",
          "commandsql": "SELECT kbi_cp.id,\n       kbi_u.firstname,\n       kbi_u.lastname,\n       kbi_u.id                                                  AS userid,\n       kbi_cp.name,\n       kbi_cp.timecreated,\n       kbi_cp.status,\n       CASE\n         WHEN ROUND((SUM(kbi_cu.proficiency) / COUNT(kbi_ctc.id)) * 100, 2) >= 100 THEN MAX(kbi_cu.timecreated)\n         ELSE 0 END                                          AS completion_date,\n       ROUND((SUM(kbi_cu.proficiency) / COUNT(kbi_ctc.id)) * 100, 2) AS progress,\n       kbi_cp.templateid\nFROM mdl_competency_template kbi_ct\n       LEFT JOIN mdl_competency_templatecomp kbi_ctc ON kbi_ctc.templateid = kbi_ct.id\n       LEFT JOIN mdl_competency_plan kbi_cp ON kbi_cp.templateid = kbi_ct.id\n       LEFT JOIN mdl_competency_usercomp kbi_cu ON kbi_cu.competencyid = kbi_ctc.competencyid AND kbi_cu.userid = kbi_cp.userid\n       LEFT JOIN mdl_user kbi_u ON kbi_u.id = kbi_cp.userid\nWHERE kbi_cp.id IS NOT NULL\nGROUP BY kbi_cp.id, kbi_u.id\nORDER BY kbi_u.lastname, kbi_u.firstname, kbi_cp.name",
          "cache": "1h",
          "reload": "none",
