          "commandsql": "SELECT kbi_u.id,\n       kbi_u.firstname,\n       kbi_u.lastname,\n       kbi_u.middlename,\n       kbi_u.email,\n       kbi_u.idnumber,\n       kbi_u.username,\n       kbi_u.phone1,\n       kbi_u.phone2,\n       kbi_u.institution,\n       kbi_u.department,\n       kbi_u.address,\n       kbi_u.city,\n       kbi_u.country,\n       kbi_u.auth,\n       kbi_u.confirmed,\n       kbi_u.suspended,\n       kbi_u.deleted,\n       kbi_u.timecreated,\n       kbi_u.timemodified,\n       kbi_u.firstaccess,\n       kbi_u.lastaccess,\n       kbi_u.lastlogin,\n       kbi_u.currentlogin,\n       kbi_u.lastip\nFROM mdl_user kbi_u\nWHERE kbi_u.id > 0\n  AND kbi_u.deleted = 0\n  AND kbi_u.suspended = 0\n  AND kbi_u.username != 'guest'\nORDER BY kbi_u.lastname, kbi_u.firstname, kbi_u.id",
