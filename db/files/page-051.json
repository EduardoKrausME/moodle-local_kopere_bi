          "commandsql": "SELECT MAX(kbi_e.id)                  AS id,\n       kbi_e.enrol                    as enrol,\n       COUNT(DISTINCT kbi_e.courseid) as courses,\n       COUNT(kbi_ue.userid)           as users,\n       COUNT(DISTINCT kbi_ue.userid)  as uniusers\nFROM mdl_enrol kbi_e\n       LEFT JOIN mdl_user_enrolments kbi_ue ON kbi_ue.enrolid = kbi_e.id\nWHERE kbi_e.id > 0\n  AND kbi_e.status = 0\n  AND kbi_ue.status = 0\nGROUP BY kbi_e.enrol\nORDER BY users DESC, kbi_e.enrol",
